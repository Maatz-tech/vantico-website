---
import Badge from './Badge.astro';

interface Props {
  badge?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { badge, title, description, align = 'left', class: className } = Astro.props;

const alignClass = align === 'center' ? 'items-center text-center' : 'items-start text-left';
---

<div class:list={['flex flex-col gap-4', alignClass, className]}>
  {badge && <Badge>{badge}</Badge>}
  <h2 class="text-h2">{title}</h2>
  {description && <p class="text-body-lg max-w-[700px]">{description}</p>}
</div>

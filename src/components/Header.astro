---
import Button from './Button.astro';
---

<header class="header" id="site-header">
  <div class="header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Vantico">
      <img src="/images/logo-vantico-header-mobile.svg" alt="Vantico" width="128" height="26" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="header__nav" aria-label="Main navigation">
      <div class="header__pill">
        <!-- Serviços -->
        <div class="header__nav-item" data-dropdown="servicos">
          <button class="header__nav-link" type="button" aria-expanded="false" aria-haspopup="true">
            Serviços
            <svg class="header__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
        </div>

        <!-- Pentest -->
        <a href="/pentest" class="header__nav-link">Pentest</a>

        <!-- Soluções -->
        <div class="header__nav-item" data-dropdown="solucoes">
          <button class="header__nav-link" type="button" aria-expanded="false" aria-haspopup="true">
            Soluções
            <svg class="header__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
        </div>

        <!-- Parceiros -->
        <a href="/parceiros" class="header__nav-link">Parceiros</a>

        <!-- Empresa -->
        <div class="header__nav-item" data-dropdown="empresa">
          <button class="header__nav-link" type="button" aria-expanded="false" aria-haspopup="true">
            Empresa
            <svg class="header__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
        </div>

        <!-- Conteúdos -->
        <div class="header__nav-item" data-dropdown="conteudos">
          <button class="header__nav-link" type="button" aria-expanded="false" aria-haspopup="true">
            Conteúdos
            <svg class="header__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Desktop CTA -->
    <div class="header__cta">
      <Button variant="primary" href="/contato">Agendar demonstração</Button>
    </div>

    <!-- Mobile Menu Button -->
    <button class="header__hamburger" id="mobile-menu-btn" type="button" aria-label="Abrir menu">
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Desktop Dropdowns -->
  <!-- Serviços Dropdown -->
  <div class="header__dropdown" id="dropdown-servicos" aria-hidden="true">
    <div class="header__dropdown-inner header__dropdown-inner--1100">
      <div class="header__dropdown-cols header__dropdown-cols--3">
        <!-- Pen Test -->
        <div class="header__dropdown-col">
          <div class="header__dropdown-heading">
            <img src="/images/icons/icon-shield-check.svg" alt="" width="16" height="16" class="header__dropdown-icon" />
            Pen Test
          </div>
          <ul class="header__dropdown-list">
            <li><a href="/servicos" class="header__dropdown-link">Web Penetration Testing</a></li>
            <li><a href="/servicos" class="header__dropdown-link">API Penetration Testing</a></li>
            <li><a href="/servicos" class="header__dropdown-link">Mobile Penetration Testing</a></li>
            <li><a href="/servicos" class="header__dropdown-link">Internal Penetration Testing</a></li>
            <li><a href="/servicos" class="header__dropdown-link">External Penetration Testing</a></li>
            <li><a href="/servicos" class="header__dropdown-link">AI Penetration Testing</a></li>
            <li><a href="/servicos" class="header__dropdown-link">Thick Client Testing</a></li>
            <li><a href="/servicos" class="header__dropdown-link">Code Assisted Pen Test (CAPT)</a></li>
            <li><a href="/servicos" class="header__dropdown-link">Source Code Review</a></li>

  }

  .header__mobile-body {
    flex: 1;
    padding: 0 var(--container-padding);
    overflow-y: auto;
  }

  .header__mobile-item {
    border-bottom: 1px solid var(--color-border);
  }

  .header__mobile-item--nested {

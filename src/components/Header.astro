---
import Button from './Button.astro';

const menuItems = [
  { label: 'Serviços', href: '/servicos', hasDropdown: true },
  { label: 'Pentest', href: '/servicos', hasDropdown: false },
  { label: 'Soluções', href: '#solucoes', hasDropdown: true },
  { label: 'Parceiros', href: '#parceiros', hasDropdown: false },
  { label: 'Empresa', href: '#empresa', hasDropdown: true },
  { label: 'Conteúdos', href: '#conteudos', hasDropdown: true },
];
---

<header class="bg-white">
  <div class="container flex items-center justify-between py-6 max-md:px-6">
    <!-- Logo -->
    <a href="/" class="shrink-0" aria-label="Vantico">
      <img src="/images/logo-vantico-header-mobile.svg" alt="Vantico" class="h-[26px] w-auto md:h-[26px] max-md:h-[24px] max-md:w-[128px]" />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center">
      <div class="flex items-center gap-6 bg-white border border-[var(--color-border)] rounded-full px-10 py-3">
        {menuItems.map((item) => (
          <a href={item.href} class="flex items-center gap-1 text-sm font-medium text-[var(--color-dark-blue)] whitespace-nowrap hover:opacity-70 transition-opacity">
            {item.label}
            {item.hasDropdown && (
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6" />
              </svg>
            )}
          </a>
        ))}
      </div>
    </nav>

    <!-- Desktop CTA -->
    <div class="hidden md:block">
      <Button variant="primary" href="#agendar">Agendar demonstração</Button>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-[var(--color-blue)]"
      aria-label="Abrir menu"
    >
      <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="6" y2="6" />
        <line x1="4" x2="20" y1="12" y2="12" />
        <line x1="4" x2="20" y1="18" y2="18" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)]">
    <div class="px-6 py-6 space-y-4">
      {menuItems.map((item) => (
        <a href={item.href} class="block text-sm font-medium text-[var(--color-dark-blue)] py-2">
          {item.label}
        </a>
      ))}
      <div class="pt-4">
        <Button variant="primary" href="#agendar" class="w-full">Agendar demonstração</Button>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

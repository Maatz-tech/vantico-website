  }

  .header__mobile-footer {
    padding: 16px var(--container-padding) 32px;
    flex-shrink: 0;
  }

  /* ── Desktop breakpoint ── */
  @media (min-width: 1024px) {
    .header__nav {
      display: flex;
      align-items: center;
    }

    .header__cta {
      display: block;
    }

    .header__hamburger {
      display: none;
    }

    .header__mobile {
      display: none !important;
    }
  }
</style>

<script>
  function initHeader() {
    // ── Desktop dropdowns ──
    const overlay = document.getElementById('header-overlay');
    let activeDropdown: string | null = null;
    let timer: number | null = null;

    function clearTimer() {
      if (timer !== null) { window.clearTimeout(timer); timer = null; }
    }

    function open(name: string) {
      clearTimer();
      if (activeDropdown === name) return;
      close();
      const trigger = document.querySelector(`.header__nav-item[data-dropdown="${name}"]`);
      const panel = document.getElementById(`dropdown-${name}`);
      if (!trigger || !panel) return;
      trigger.classList.add('header__nav-item--open');
      trigger.querySelector('button')?.setAttribute('aria-expanded', 'true');
      panel.classList.add('header__dropdown--open');
      panel.setAttribute('aria-hidden', 'false');
      overlay?.classList.add('header__overlay--active');
      activeDropdown = name;
    }

    function close() {
      clearTimer();
      document.querySelectorAll('.header__nav-item--open').forEach(el => {
        el.classList.remove('header__nav-item--open');
        el.querySelector('button')?.setAttribute('aria-expanded', 'false');
      });
      document.querySelectorAll('.header__dropdown--open').forEach(el => {
        el.classList.remove('header__dropdown--open');
        el.setAttribute('aria-hidden', 'true');
      });
      overlay?.classList.remove('header__overlay--active');
      activeDropdown = null;
    }

    function delayedClose() {
      clearTimer();
      timer = window.setTimeout(close, 200);
    }

    // Triggers: each nav-item with data-dropdown
    document.querySelectorAll<HTMLDivElement>('.header__nav-item[data-dropdown]').forEach(item => {
      const name = item.dataset.dropdown!;

      item.addEventListener('mouseenter', () => open(name));
      item.addEventListener('mouseleave', delayedClose);

      item.querySelector('button')?.addEventListener('click', () => {
        if (activeDropdown === name) close(); else open(name);
      });
    });

    // Panels: each dropdown
    document.querySelectorAll<HTMLDivElement>('.header__dropdown').forEach(panel => {
      panel.addEventListener('mouseenter', clearTimer);
      panel.addEventListener('mouseleave', delayedClose);
    });

    // Plain nav links close dropdown
    document.querySelectorAll<HTMLAnchorElement>('.header__pill > a.header__nav-link').forEach(link => {
      link.addEventListener('mouseenter', close);
    });

    overlay?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    window.addEventListener('scroll', () => { if (activeDropdown) close(); }, { passive: true });

    // ── Mobile menu ──
    const menuBtn = document.getElementById('mobile-menu-btn');
    const closeBtn = document.getElementById('mobile-close-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    function openMobileMenu() {
      mobileMenu?.classList.add('header__mobile--open');
      mobileMenu?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeMobileMenu() {
      mobileMenu?.classList.remove('header__mobile--open');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    menuBtn?.addEventListener('click', openMobileMenu);
    closeBtn?.addEventListener('click', closeMobileMenu);

    // Mobile accordions
    const accordions = document.querySelectorAll<HTMLDivElement>('[data-mobile-accordion]');
    accordions.forEach(item => {
      const btn = item.querySelector(':scope > .header__mobile-btn');
      btn?.addEventListener('click', () => {
        const isExpanded = item.classList.contains('header__mobile-item--expanded');
        if (isExpanded) {
          item.classList.remove('header__mobile-item--expanded');
          btn.setAttribute('aria-expanded', 'false');
          const sub = item.querySelector(':scope > .header__mobile-sub');
          sub?.setAttribute('aria-hidden', 'true');
        } else {
          item.classList.add('header__mobile-item--expanded');
          btn.setAttribute('aria-expanded', 'true');
          const sub = item.querySelector(':scope > .header__mobile-sub');
          sub?.setAttribute('aria-hidden', 'false');
        }
      });
    });
  }

  // Init on load
  initHeader();

  // Re-init on Astro page transitions
  document.addEventListener('astro:after-swap', initHeader);
</script>

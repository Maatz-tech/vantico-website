    padding: 24px;
  }

  .header__dropdown-card-img {
    height: 140px;
    width: 280px;
    border-radius: 12px;
    object-fit: cover;
  }

  .header__dropdown-card-img--cases {
    background-color: #EBF1FC;
  }

  .header__dropdown-card-img--gradient {
    background: linear-gradient(135deg, #1C51C6 0%, #6C4CE0 50%, #1C51C6 100%);
  }

  .header__dropdown-card-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .header__dropdown-card-title {
    font-size: 16px;
    font-weight: 500;
    color: var(--color-dark-blue);
    line-height: normal;
  }

  .header__dropdown-card-desc {
    font-size: 14px;
    font-weight: 400;
    color: var(--color-text-dark);
    line-height: 18px;
  }

  .header__dropdown-card-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;

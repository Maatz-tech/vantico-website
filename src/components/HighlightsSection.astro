---
import Button from './Button.astro';

const highlights = [
  { value: '98%', numericValue: 98, prefix: '', suffix: '%', description: 'De comprometimento em ambientes críticos' },
  { value: 'R$15B', numericValue: 15, prefix: 'R$', suffix: 'B', description: 'Valor de mercado protegido' },
  { value: '5', numericValue: 5, prefix: '', suffix: '', description: 'Anos dedicado a segurança ofensiva' },
  { value: '+ 150', numericValue: 150, prefix: '+ ', suffix: '', description: 'Clientes satisfeitos no Brasil e no mundo' },
];
---

<section class="highlights">
  <div class="highlights__header">
    <h2 class="highlights__title" data-animate data-animate-type="typing">Segurança ofensiva com excelência técnica</h2>
    <p class="highlights__subtitle" data-animate>
      Nossa equipe é formada por profissionais experientes e atualizados, permitindo que sua equipe tome decisões rápidas e estratégicas.
    </p>
  </div>

  <div class="highlights__stats-wrap">
    <!-- Grid lines decorativas ancoradas ao stats -->
    <div class="highlights__grid" aria-hidden="true">
      <div class="highlights__grid-line highlights__grid-line--h highlights__grid-line--h1"></div>
      <div class="highlights__grid-line highlights__grid-line--h highlights__grid-line--h2"></div>
      <div class="highlights__grid-line highlights__grid-line--v highlights__grid-line--v1"></div>
      <div class="highlights__grid-line highlights__grid-line--v highlights__grid-line--v2"></div>
    </div>

    <div class="highlights__stats">
      {highlights.map((item, i) => (
        <div class:list={['highlights__stat', { 'highlights__stat--last': i === highlights.length - 1 }]}>
          <div class="highlights__stat-bg" aria-hidden="true"></div>
          <p class="highlights__stat-value">{item.prefix}<span data-odometer={String(item.numericValue)}>{String(item.numericValue)}</span>{item.suffix}</p>
          <p class="highlights__stat-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>

  <div data-animate>
    <Button variant="primary" href="/contato">Agende uma demo</Button>
  </div>
</section>

<script>
  function initOdometers() {
    const elements = document.querySelectorAll('[data-odometer]');
    if (!elements.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          buildOdometer(entry.target as HTMLElement);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    elements.forEach((el) => observer.observe(el));
  }

  function buildOdometer(el: HTMLElement) {
    const target = parseInt(el.dataset.odometer || '0', 10);
    const duration = 1800;
    const start = performance.now();

    function update(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      el.textContent = String(Math.round(eased * target));
      if (progress < 1) requestAnimationFrame(update);
    }

    requestAnimationFrame(update);
  }

  initOdometers();
  document.addEventListener('astro:after-swap', initOdometers);
</script>

<style>
  .highlights {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 64px;
    padding: 80px max(var(--container-padding), calc((100% - var(--container-max)) / 2));
    background-color: var(--color-white-2);
    overflow: hidden;
  }

  /* Stats wrapper (anchor for grid lines) */
  .highlights__stats-wrap {
    position: relative;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
  }

  /* Grid lines */
  .highlights__grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .highlights__grid-line--h {
    position: absolute;
    left: -40px;
    right: -40px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      rgba(25, 31, 47, 0.1) 10%,
      rgba(25, 31, 47, 0.1) 90%,
      transparent 100%
    );
  }

  .highlights__grid-line--h1 {
    top: 0;
  }

  .highlights__grid-line--h2 {
    bottom: 0;
  }

  .highlights__grid-line--v {
    position: absolute;
    top: -40px;
    bottom: -40px;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(25, 31, 47, 0.1) 15%,
      rgba(25, 31, 47, 0.1) 85%,
      transparent 100%
    );
  }

  .highlights__grid-line--v1 {
    left: 0;
  }

  .highlights__grid-line--v2 {
    right: 0;
  }

  /* Header */
  .highlights__header {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    max-width: 900px;
    text-align: center;
    padding: 0 var(--container-padding);
  }

  .highlights__title {
    font-size: 40px;
    font-weight: 500;
    line-height: normal;
    letter-spacing: 0;
    color: var(--color-dark-blue);
  }

  .highlights__subtitle {
    font-size: 20px;
    font-weight: 400;
    line-height: normal;
    color: var(--color-text-dark);
  }

  /* Stats */
  .highlights__stats {
    position: relative;
    z-index: 1;
    display: flex;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    background-color: var(--color-white);
  }

  .highlights__stat {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    height: 161px;
    border-right: 1px solid var(--color-border);
    overflow: hidden;
    cursor: default;
    transition: background-color 0.3s ease;
  }

  .highlights__stat-bg {
    position: absolute;
    inset: 0;
    background-color: var(--color-blue-light);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 0;
  }

  .highlights__stat-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.5;
    background-repeat: no-repeat;
    background-position: right center;
    background-size: cover;
  }

  .highlights__stat:nth-child(1) .highlights__stat-bg::after {
    background-image: url('/images/highlights/hover-1.svg');
  }

  .highlights__stat:nth-child(2) .highlights__stat-bg::after {
    background-image: url('/images/highlights/hover-2.svg');
  }

  .highlights__stat:nth-child(3) .highlights__stat-bg::after {
    background-image: url('/images/highlights/hover-3.svg');
  }

  .highlights__stat:nth-child(4) .highlights__stat-bg::after {
    background-image: url('/images/highlights/hover-4.svg');
  }

  .highlights__stat:hover .highlights__stat-bg {
    opacity: 1;
  }

  .highlights__stat--last {
    border-right: none;
  }

  .highlights__stat-value {
    position: relative;
    z-index: 1;
    font-size: 48px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-dark-blue);
    transition: color 0.3s ease;
  }

  .highlights__stat:hover .highlights__stat-value {
    color: var(--color-blue);
  }

  .highlights__stat-desc {
    position: relative;
    z-index: 1;
    font-size: 14px;
    font-weight: 400;
    line-height: 18px;
    color: var(--color-text-dark);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: font-weight 0.3s ease;
  }

  .highlights__stat:hover .highlights__stat-desc {
    font-weight: 500;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .highlights {
      gap: 40px;
      padding: 48px 0;
    }

    .highlights__grid {
      display: none;
    }

    .highlights__stats-wrap {
      max-width: none;
      padding: 0 var(--container-padding);
    }

    .highlights__title {
      font-size: 24px;
      line-height: 32px;
    }

    .highlights__subtitle {
      font-size: 16px;
      line-height: normal;
    }

    .highlights__header {
      max-width: 327px;
    }

    .highlights__stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      max-width: none;
      width: 100%;
    }

    .highlights__stat {
      height: auto;
      min-height: 140px;
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .highlights__stat:nth-child(odd) {
      border-right: 1px solid var(--color-border);
    }

    .highlights__stat:nth-last-child(-n+2) {
      border-bottom: none;
    }

    .highlights__stat-value {
      font-size: 36px;
    }
  }
</style>

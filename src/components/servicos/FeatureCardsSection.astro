---
/**
 * FeatureCardsSection
 * "Quem pode se proteger com Pentests" - Grid of cards with icon + title + description.
 * Figma refs: Desktop 4411:1165 area, Mobile 4411:1165
 */

const cards = [
  {
    icon: 'database',
    title: 'Empresas com dados sensíveis',
    description: "Organizações que processam dados financeiros, pessoais ou estratégicos, como e-commerces, fintechs e plataformas SaaS.",
  },
  {
    icon: 'rocket',
    title: 'Pré-lançamento de sistemas',
    description: '',
  },
  {
    icon: 'shield',
    title: 'Requisitos regulatórios e compliance',
    description: '',
  },
  {
    icon: 'refresh',
    title: 'Times com operação contínua',
    description: '',
  },
];
---

<section class="feature-cards">
  <div class="feature-cards__container">
    <!-- Header -->
    <div class="feature-cards__header">
      <div class="feature-cards__badge">
        <span class="feature-cards__badge-dot"></span>
        <span class="feature-cards__badge-text">Casos de uso</span>
      </div>
      <h2 class="feature-cards__title">Quem pode se proteger com Pentests</h2>
    </div>

    <!-- Cards list -->
    <div class="feature-cards__list">
      {cards.map((card, i) => (
        <div class:list={['feature-cards__item', { 'feature-cards__item--expanded': i === 0 }]}>
          <div class="feature-cards__item-header">
            <div class="feature-cards__icon-wrap">
              {card.icon === 'database' && (
                <svg class="feature-cards__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-dark-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <ellipse cx="12" cy="5" rx="9" ry="3" />
                  <path d="M3 5V19A9 3 0 0 0 21 19V5" />
                  <path d="M3 12A9 3 0 0 0 21 12" />
                </svg>
              )}
              {card.icon === 'rocket' && (
                <svg class="feature-cards__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-dark-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
                  <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
                  <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
                  <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
                </svg>
              )}
              {card.icon === 'shield' && (
                <svg class="feature-cards__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-dark-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
                  <path d="m9 12 2 2 4-4" />
                </svg>
              )}
              {card.icon === 'refresh' && (
                <svg class="feature-cards__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-dark-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
                  <path d="M3 3v5h5" />
                  <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16" />
                  <path d="M16 16h5v5" />
                </svg>
              )}
            </div>
            <h3 class="feature-cards__item-title">{card.title}</h3>
          </div>
          {card.description && (
            <div class="feature-cards__item-body">
              <p class="feature-cards__item-desc">{card.description}</p>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .feature-cards {
    padding: 48px 0;
    background-color: var(--color-white);
    overflow: hidden;
  }

  .feature-cards__container {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
  }

  /* Badge */
  .feature-cards__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 100px;
    border: 1px solid var(--color-border);
    background-color: var(--color-white);
  }

  .feature-cards__badge-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-blue);
  }

  .feature-cards__badge-text {
    font-size: 14px;
    font-weight: 500;
    line-height: 19px;
    color: var(--color-blue);
    white-space: nowrap;
  }

  /* Header */
  .feature-cards__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    width: 100%;
  }

  .feature-cards__title {
    font-size: 24px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
  }

  /* Cards list */
  .feature-cards__list {
    width: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Card item */
  .feature-cards__item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px 0;
    border-bottom: 1px solid var(--color-border-solid);
  }

  .feature-cards__item:first-child {
    padding-top: 0;
  }

  .feature-cards__item:last-child {
    border-bottom: 1px solid var(--color-border-solid);
  }

  .feature-cards__item-header {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .feature-cards__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 100px;
    border: 0.8px solid var(--color-border-solid);
    background-color: var(--color-white);
    flex-shrink: 0;
  }

  .feature-cards__icon {
    display: block;
  }

  .feature-cards__item-title {
    font-size: 18px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
  }

  .feature-cards__item-body {
    width: 100%;
  }

  .feature-cards__item-desc {
    font-size: 16px;
    font-weight: 400;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .feature-cards {
      padding: 80px 0;
    }

    .feature-cards__container {
      flex-direction: row;
      gap: 48px;
      align-items: flex-start;
    }

    .feature-cards__header {
      align-items: flex-start;
      text-align: left;
      flex: 0 0 auto;
      max-width: 340px;
    }

    .feature-cards__title {
      font-size: 32px;
    }

    .feature-cards__list {
      flex: 1;
      min-width: 0;
    }
  }
</style>

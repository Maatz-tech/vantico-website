---
---

<section class="simulation">
  <div class="simulation__container">
    <!-- Illustration (left on desktop) -->
    <div class="simulation__illustration" data-animate="fade-up">
      <div class="simulation__visual">
        <!-- Background circles -->
        <img src="/images/servicos/pentest-simulation.svg" alt="" class="simulation__circles" aria-hidden="true" />

        <!-- Code window -->
        <div class="simulation__code-window">
          <div class="simulation__code-bar">
            <div class="simulation__code-bar-line"></div>
            <div class="simulation__code-bar-dots">
              <span></span><span></span><span></span>
            </div>
          </div>
          <div class="simulation__code-body">
            <p>UPDATE system_logs</p>
            <p>SET message = 'User authentication succeeded with elevated privileges after multi-factor validation',</p>
            <p>&nbsp;&nbsp;&nbsp;&nbsp;context_json = '&#123;"module":"auth","action":"login","mfa":true, "latency_ms":842,"source":"web"&#125;',</p>
            <p>&nbsp;&nbsp;&nbsp;&nbsp;severity = 'INFO',</p>
            <p>&nbsp;&nbsp;&nbsp;&nbsp;processed_at = '2026-02-26 15:08:49'</p>
            <p>WHERE log_id = 553210 AND environment = 'production';</p>
            <p>SELECT u.id, u.full_name, t.reference_code, t.amount, t.status, t.created_at</p>
          </div>
        </div>

        <!-- Center badge -->
        <div class="simulation__badge">
          <div class="simulation__badge-inner">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L4 6v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V6l-8-4z" fill="white" opacity="0.3"/>
              <path d="M12 2L4 6v6c0 5.55 3.84 10.74 8 12 4.16-1.26 8-6.45 8-12V6l-8-4zm-1 15l-4-4 1.41-1.41L11 14.17l5.59-5.59L18 10l-7 7z" fill="white"/>
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Text (right on desktop) -->
    <div class="simulation__text">
      <h2 class="simulation__title" data-animate="blur-in">Simule ataques reais para identificar vulnerabilidades</h2>
      <p class="simulation__paragraph" data-animate="fade-up">
        O Pentest (teste de intrusão) é uma avaliação prática de segurança que simula o comportamento de um invasor em ambientes reais, como aplicações web, APIs, redes e sistemas internos. Diferente de ferramentas automatizadas (scanners ou soluções SaaS), o Pentest envolve análise manual, raciocínio adversarial e uso de técnicas avançadas.
      </p>
      <blockquote class="simulation__quote" data-animate="fade-up">
        <p>
          Isso permite identificar vulnerabilidades complexas, falhas de lógica e encadeamentos de ataque que normalmente passam despercebidos por ferramentas automáticas.
        </p>
      </blockquote>
    </div>
  </div>
</section>

<style>
  .simulation {
    background-color: var(--color-white);
    padding: 48px var(--container-padding);
  }

  .simulation__container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Illustration */
  .simulation__illustration {
    width: 100%;
  }

  .simulation__visual {
    position: relative;
    width: 100%;
    aspect-ratio: 400 / 267;
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }

  .simulation__circles {
    position: absolute;
    bottom: -60%;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: auto;
    pointer-events: none;
    opacity: 0.5;
  }

  .simulation__code-window {
    position: absolute;
    top: 15%;
    left: 18%;
    width: 64%;
    height: 70%;
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-shadow: var(--shadow-1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .simulation__code-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 11px;
    flex-shrink: 0;
  }

  .simulation__code-bar-line {
    width: 60%;
    height: 6px;
    background: linear-gradient(to right, var(--color-blue), rgba(28, 81, 198, 0.2));
    border-radius: 3px;
  }

  .simulation__code-bar-dots {
    display: flex;
    gap: 3px;
  }

  .simulation__code-bar-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-border-solid);
  }

  .simulation__code-body {
    padding: 0 11px 11px;
    font-family: 'Consolas', 'Courier New', monospace;
    font-size: 7px;
    line-height: normal;
    color: rgba(25, 31, 47, 0.2);
    overflow: hidden;
    flex: 1;
  }

  .simulation__code-body p {
    margin: 0;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .simulation__badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 6px;
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 100px;
  }

  .simulation__badge-inner {
    width: 32px;
    height: 32px;
    border-radius: 100px;
    background-color: var(--color-blue);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Text */
  .simulation__title {
    font-size: 32px;
    font-weight: 500;
    line-height: 40px;
    color: var(--color-dark-blue);
    margin: 0;
  }

  .simulation__text {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .simulation__paragraph {
    font-size: 16px;
    font-weight: 400;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
  }

  .simulation__quote {
    border-left: 2px solid var(--color-blue);
    padding-left: 16px;
    margin: 0;
  }

  .simulation__quote p {
    font-size: 16px;
    font-weight: 400;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .simulation {
      padding: 80px 120px;
    }

    .simulation__container {
      flex-direction: row;
      align-items: center;
      gap: 80px;
    }

    .simulation__illustration {
      width: 400px;
      flex-shrink: 0;
    }

    .simulation__visual {
      width: 400px;
      height: 267px;
      aspect-ratio: auto;
    }

    .simulation__code-body {
      font-size: 9px;
    }

    .simulation__text {
      flex: 1;
      min-width: 0;
    }

    .simulation__title {
      font-size: 40px;
      line-height: 48px;
    }
  }
</style>

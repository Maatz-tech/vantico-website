---
/**
 * ProcessTimeline
 * Horizontal timeline with 6 pentest process steps.
 * Figma refs: Desktop 4467:3142, Mobile 4467:3142
 */

const steps = [
  {
    step: 'Etapa 1',
    title: 'Kick-off e Planejamento',
    icon: 'clipboard',
  },
  {
    step: 'Etapa 2',
    title: 'Reconhecimento e Varredura',
    icon: 'search',
  },
  {
    step: 'Etapa 3',
    title: 'Modelagem de Ameaças',
    icon: 'target',
  },
  {
    step: 'Etapa 4',
    title: 'Identificação de Vulnerabilidades',
    icon: 'bug',
  },
  {
    step: 'Etapa 5',
    title: 'Exploração de Vulnerabilidades',
    icon: 'zap',
  },
  {
    step: 'Etapa 6',
    title: 'Pós exploração e Relatório',
    icon: 'file',
  },
];
---

<section class="process-timeline">
  <div class="process-timeline__container">
    <h2 class="process-timeline__heading">Nosso processo de Pentest</h2>

    <div class="process-timeline__track-wrap">
      <!-- Top horizontal line -->
      <div class="process-timeline__line process-timeline__line--top" aria-hidden="true"></div>
      <!-- Bottom horizontal line -->
      <div class="process-timeline__line process-timeline__line--bottom" aria-hidden="true"></div>
      <!-- Fade edges -->
      <div class="process-timeline__fade process-timeline__fade--left" aria-hidden="true"></div>
      <div class="process-timeline__fade process-timeline__fade--right" aria-hidden="true"></div>

      <div class="process-timeline__track">
        {steps.map((item) => (
          <div class="process-timeline__step">
            <div class="process-timeline__step-header">
              <div class="process-timeline__icon-wrap">
                {item.icon === 'clipboard' && (
                  <svg class="process-timeline__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="8" height="4" x="8" y="2" rx="1" ry="1" />
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2" />
                  </svg>
                )}
                {item.icon === 'search' && (
                  <svg class="process-timeline__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.3-4.3" />
                  </svg>
                )}
                {item.icon === 'target' && (
                  <svg class="process-timeline__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <circle cx="12" cy="12" r="6" />
                    <circle cx="12" cy="12" r="2" />
                  </svg>
                )}
                {item.icon === 'bug' && (
                  <svg class="process-timeline__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m8 2 1.88 1.88" /><path d="M14.12 3.88 16 2" />
                    <path d="M9 7.13v-1a3.003 3.003 0 1 1 6 0v1" />
                    <path d="M12 20c-3.3 0-6-2.7-6-6v-3a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v3c0 3.3-2.7 6-6 6" />
                    <path d="M12 20v-9" /><path d="M6.53 9C4.6 8.8 3 7.1 3 5" />
                    <path d="M6 13H2" /><path d="M3 21c0-2.1 1.7-3.9 3.8-4" />
                    <path d="M20.97 5c0 2.1-1.6 3.8-3.5 4" /><path d="M22 13h-4" />
                    <path d="M17.2 17c2.1.1 3.8 1.9 3.8 4" />
                  </svg>
                )}
                {item.icon === 'zap' && (
                  <svg class="process-timeline__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" />
                  </svg>
                )}
                {item.icon === 'file' && (
                  <svg class="process-timeline__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-blue)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                    <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                    <path d="M10 9H8" /><path d="M16 13H8" /><path d="M16 17H8" />
                  </svg>
                )}
              </div>
              <div class="process-timeline__step-info">
                <span class="process-timeline__step-label">{item.step}</span>
                <span class="process-timeline__step-title">{item.title}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .process-timeline {
    padding: 48px 0;
    background-color: var(--color-white-2);
    overflow: hidden;
  }

  .process-timeline__container {
    width: 100%;
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
  }

  .process-timeline__heading {
    font-size: 24px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-dark-blue);
    text-align: center;
    margin: 0;
    padding: 0 var(--container-padding);
  }

  /* Track wrapper - contains lines + fade + scrollable track */
  .process-timeline__track-wrap {
    position: relative;
    width: 100%;
  }

  /* Horizontal lines */
  .process-timeline__line {
    position: absolute;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-border-solid) 15%,
      var(--color-border-solid) 85%,
      transparent 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .process-timeline__line--top {
    top: 0;
  }

  .process-timeline__line--bottom {
    bottom: 0;
  }

  /* Fade edges */
  .process-timeline__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 24px;
    z-index: 2;
    pointer-events: none;
  }

  .process-timeline__fade--left {
    left: 0;
    background: linear-gradient(90deg, var(--color-white-2), transparent);
  }

  .process-timeline__fade--right {
    right: 0;
    background: linear-gradient(270deg, var(--color-white-2), transparent);
  }

  /* Scrollable track */
  .process-timeline__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .process-timeline__track::-webkit-scrollbar {
    display: none;
  }

  /* Step card */
  .process-timeline__step {
    flex: 0 0 342px;
    min-width: 342px;
    padding: 24px;
    background-color: var(--color-white);
    border-left: 1px solid var(--color-border-solid);
    border-right: 1px solid var(--color-border-solid);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .process-timeline__step + .process-timeline__step {
    border-left: none;
  }

  .process-timeline__step-header {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .process-timeline__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 100px;
    border: 0.8px solid var(--color-border-solid);
    background-color: var(--color-white);
    flex-shrink: 0;
  }

  .process-timeline__icon {
    display: block;
  }

  .process-timeline__step-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .process-timeline__step-label {
    font-size: 14px;
    font-weight: 400;
    line-height: 18px;
    color: var(--color-text-dark);
  }

  .process-timeline__step-title {
    font-size: 18px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-text-dark);
  }

  /* Desktop */
  @media (min-width: 768px) {
    .process-timeline {
      padding: 80px 0;
    }

    .process-timeline__heading {
      font-size: 32px;
    }

    .process-timeline__track {
      overflow-x: visible;
      justify-content: center;
    }

    .process-timeline__step {
      flex: 1;
      min-width: 0;
    }

    .process-timeline__fade {
      display: none;
    }
  }
</style>

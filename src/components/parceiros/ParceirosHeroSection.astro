---
import Badge from '../Badge.astro';
import Button from '../Button.astro';
---

<section class="parceiros-hero">
  <div class="parceiros-hero__pattern" aria-hidden="true">
    <img src="/images/pentest/hero-pattern.svg" alt="" />
  </div>

  <div class="parceiros-hero__content">
    <Badge>Parceiros Vantico</Badge>
    <h1 class="parceiros-hero__title" data-animate data-animate-type="typing">O programa que potencializa os resultados da sua empresa</h1>
    <div data-animate>
      <Button variant="primary" href="/contato">Fale com um especialista</Button>
    </div>
  </div>
</section>

<style>
  .parceiros-hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    padding: 64px max(var(--container-padding), calc((100% - var(--container-max)) / 2)) 64px;
    background-color: var(--color-white);
    overflow: hidden;
  }

  .parceiros-hero__pattern {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 1440px;
    height: 623px;
    pointer-events: none;
    z-index: 0;
  }

  .parceiros-hero__pattern img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .parceiros-hero__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    max-width: 800px;
    text-align: center;
  }

  .parceiros-hero__title {
    font-size: 52px;
    font-weight: 500;
    line-height: 56px;
    color: var(--color-dark-blue);
    margin: 0;
  }

  @media (max-width: 767px) {
    .parceiros-hero {
      padding: 48px var(--container-padding);
    }

    .parceiros-hero__pattern {
      width: 840px;
      height: 364px;
    }

    .parceiros-hero__content {
      gap: 16px;
    }

    .parceiros-hero__title {
      font-size: 32px;
      line-height: 40px;
    }
  }
</style>

---
const placeholders = [1, 2, 3, 4, 5];
---

<section class="logos-parceiros">
  <div class="logos-parceiros__lines" aria-hidden="true">
    <div class="logos-parceiros__line logos-parceiros__line--h1"></div>
    <div class="logos-parceiros__line logos-parceiros__line--h2"></div>
  </div>
  <div class="logos-parceiros__container">
    <p class="logos-parceiros__text" data-animate>Confiança de quem já é um Parceiro Vantico</p>
    <div class="logos-parceiros__row" data-animate>
      {placeholders.map(() => (
        <div class="logos-parceiros__placeholder"></div>
      ))}
    </div>
  </div>
</section>

<style>
  .logos-parceiros {
    position: relative;
    background-color: var(--color-white);
    padding: 0;
  }

  .logos-parceiros__lines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .logos-parceiros__line--h1,
  .logos-parceiros__line--h2 {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    height: 1px;
    background: linear-gradient(to right, transparent 0%, rgba(25,31,47,0.1) 15%, rgba(25,31,47,0.1) 85%, transparent 100%);
  }

  .logos-parceiros__line--h1 { top: 0; }
  .logos-parceiros__line--h2 { bottom: 0; }

  .logos-parceiros__container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-padding);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    min-height: 104px;
    justify-content: center;
  }

  .logos-parceiros__text {
    font-size: 16px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
    white-space: nowrap;
    text-align: center;
  }

  .logos-parceiros__row {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .logos-parceiros__placeholder {
    width: 80px;
    height: 24px;
    background: var(--color-border-solid);
    border-radius: 4px;
    opacity: 0.5;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .logos-parceiros__container {
      flex-direction: row;
      justify-content: space-between;
      padding: 0;
    }

    .logos-parceiros__row {
      flex-wrap: nowrap;
      gap: 40px;
    }

    .logos-parceiros__placeholder {
      width: 100px;
    }
  }
</style>

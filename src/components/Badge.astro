---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['inline-flex items-center gap-3 rounded-full border border-[var(--color-border)] px-3 py-2', className]}>
  <span class="block w-1.5 h-1.5 rounded-full bg-[var(--color-blue)]"></span>
  <span class="text-[14px] text-[var(--color-blue)] font-medium leading-[19px]">
    <slot />
  </span>
</div>

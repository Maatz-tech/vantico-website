---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import BlogCard from '../../components/BlogCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const labsPosts = posts.filter((p) => p.data.category === 'Labs');
  return labsPosts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

const allPosts = await getCollection('blog');
const labsPosts = allPosts.filter((p) => p.data.category === 'Labs');
const sortedPosts = labsPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const relatedPosts = sortedPosts.filter(p => p.id !== post.id).slice(0, 3);

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('pt-BR', { month: 'short', day: 'numeric', year: 'numeric' });
}

const postUrl = `https://vantico.com.br/labs/${post.id}`;
const shareUrls = {
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`,
  twitter: `https://twitter.com/intent/tweet?url=${encodeURIComponent(postUrl)}&text=${encodeURIComponent(post.data.title)}`,
};
---

<Base title={`${post.data.title} | Vantico Labs`} description={post.data.summary} ogImage={post.data.image} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.summary,
    "image": new URL(post.data.image, 'https://vantico.com.br').href,
    "datePublished": post.data.date,
    "author": {
      "@type": "Person",
      "name": post.data.author
    },
    "publisher": {
      "@type": "Organization",
      "name": "Vantico",
      "url": "https://vantico.com.br"
    }
  })} />
  <Header />

  <main>
  <!-- Post Hero -->
  <section class="labspost-hero">
    <div class="labspost-hero__pattern" aria-hidden="true">
      <img src="/images/hero-pattern.svg" alt="" />
    </div>
    <div class="labspost-hero__container">
      <div class="labspost-hero__left">
        <a href="/labs" class="labspost-hero__back">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
          </svg>
          <span>Voltar</span>
        </a>
        <h1 class="labspost-hero__title">{post.data.title}</h1>
        {post.data.tags.length > 0 && (
          <div class="labspost-hero__tags">
            {post.data.tags.map((tag) => (
              <span class="labspost-hero__tag">{tag}</span>
            ))}
          </div>
        )}
        <div class="labspost-hero__date">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
        </div>
      </div>
      <div class="labspost-hero__right">
        <img
          src={post.data.image}
          alt={post.data.title}
          class="labspost-hero__image"
          loading="eager"
          width="960"
          height="500"
        />
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <article class="labspost-article">
    <div class="labspost-article__container">
      <div class="labspost__body">
        <Content />
      </div>

      <hr class="labspost__divider" />

      <!-- Author + Share Row -->
      <div class="labspost__author-share">
        <div class="labspost__author">
          <img
            src={post.data.authorImage}
            alt={post.data.author}
            class="labspost__author-avatar"
            loading="lazy"
          />
          <span class="labspost__author-name">{post.data.author}</span>
        </div>
        <div class="labspost__share">
          <span class="labspost__share-label">Compartilhe</span>
          <div class="labspost__share-icons">
            <a href={shareUrls.facebook} target="_blank" rel="noopener noreferrer" aria-label="Compartilhar no Facebook" class="labspost__share-link">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href={shareUrls.linkedin} target="_blank" rel="noopener noreferrer" aria-label="Compartilhar no LinkedIn" class="labspost__share-link">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" aria-label="Compartilhar no Twitter" class="labspost__share-link">
              <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <button class="labspost__share-link" aria-label="Copiar link" id="copy-link-btn" data-url={postUrl}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>
      </div>

      <hr class="labspost__divider" />

      <!-- Prev/Next Navigation -->
      <nav class="labspost__nav">
        {prevPost ? (
          <a href={`/labs/${prevPost.id}`} class="labspost__nav-link labspost__nav-link--prev">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6" />
            </svg>
            <span>Anterior</span>
          </a>
        ) : <div />}
        {nextPost ? (
          <a href={`/labs/${nextPost.id}`} class="labspost__nav-link labspost__nav-link--next">
            <span>Proximo</span>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </a>
        ) : <div />}
      </nav>
    </div>
  </article>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="labspost-related">
      <div class="labspost-related__container">
        <div class="labspost-related__header">
          <h2 class="labspost-related__title">Leia mais artigos</h2>
          <div class="labspost-related__btn-desktop">
            <Button variant="outline" href="/labs" icon>Ver todos</Button>
          </div>
        </div>
        <div class="labspost-related__grid">
          {relatedPosts.map((relatedPost) => (
            <BlogCard
              title={relatedPost.data.title}
              summary={relatedPost.data.summary}
              image={relatedPost.data.image}
              date={formatDate(relatedPost.data.date)}
              slug={relatedPost.id}
              basePath="/labs"
            />
          ))}
        </div>
        <div class="labspost-related__btn-mobile">
          <Button variant="outline" href="/labs" icon>Ver todos</Button>
        </div>
      </div>
    </section>
  )}

  </main>
  <Footer />
</Base>

<script>
  const copyBtn = document.getElementById('copy-link-btn');
  copyBtn?.addEventListener('click', async () => {
    const url = copyBtn.getAttribute('data-url');
    if (url) {
      try {
        await navigator.clipboard.writeText(url);
      } catch {
        const textarea = document.createElement('textarea');
        textarea.value = url;
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      }
    }
  });
</script>

<style>
  /* ========================
     POST HERO — identical to blog post
     ======================== */
  .labspost-hero {
    position: relative;
    background-color: var(--color-white-2);
    border-bottom: 1px solid var(--color-border-solid);
    overflow: clip;
    padding: 48px 24px 40px;
  }

  .labspost-hero__pattern {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.5;
  }

  .labspost-hero__pattern img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .labspost-hero__container {
    position: relative;
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .labspost-hero__left {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .labspost-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-dark-blue);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .labspost-hero__back:hover {
    opacity: 0.7;
  }

  .labspost-hero__title {
    font-size: 24px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
  }

  .labspost-hero__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .labspost-hero__tag {
    display: inline-flex;
    align-items: center;
    padding: 8px 12px;
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-blue);
    line-height: normal;
  }

  .labspost-hero__date {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--color-text-dark);
    line-height: normal;
  }

  .labspost-hero__date svg {
    flex-shrink: 0;
    color: var(--color-text-dark);
  }

  .labspost-hero__right {
    width: 100%;
  }

  .labspost-hero__image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 768px) {
    .labspost-hero {
      padding-top: 64px;
      padding-bottom: 56px;
      padding-left: max(24px, calc((100% - 1000px) / 2));
      padding-right: max(24px, calc((100% - 1000px) / 2));
    }

    .labspost-hero__container {
      flex-direction: row;
      gap: 40px;
      align-items: flex-start;
    }

    .labspost-hero__left {
      flex: 1;
      min-width: 0;
    }

    .labspost-hero__title {
      font-size: 40px;
    }

    .labspost-hero__right {
      width: 480px;
      flex-shrink: 0;
    }

    .labspost-hero__image {
      width: 480px;
      height: 250px;
    }
  }

  /* ========================
     ARTICLE BODY — identical to blog post
     ======================== */
  .labspost-article {
    background-color: var(--color-white);
    padding: 40px 24px 80px;
  }

  .labspost-article__container {
    max-width: var(--container-max);
    margin: 0 auto;
  }

  .labspost__body {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .labspost__body :global(p) {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text-dark);
    font-weight: 400;
    margin: 0;
  }

  .labspost__body :global(h2) {
    font-size: 24px;
    font-weight: bold;
    color: var(--color-dark-blue);
    margin: 0;
    line-height: normal;
  }

  .labspost__body :global(h3) {
    font-size: 20px;
    font-weight: bold;
    color: var(--color-dark-blue);
    margin: 0;
    line-height: normal;
  }

  .labspost__body :global(h4) {
    font-size: 18px;
    font-weight: bold;
    color: var(--color-dark-blue);
    margin: 0;
    line-height: normal;
  }

  .labspost__body :global(strong) {
    font-weight: bold;
    color: var(--color-text-dark);
  }

  .labspost__body :global(a) {
    font-weight: 500;
    color: var(--color-dark-blue);
    text-decoration: underline;
  }

  .labspost__body :global(a:hover) {
    opacity: 0.7;
  }

  .labspost__body :global(ul),
  .labspost__body :global(ol) {
    margin: 0;
    margin-left: 24px;
    padding: 0;
    font-size: 16px;
    line-height: 24px;
    color: var(--color-text-dark);
  }

  .labspost__body :global(li) {
    margin: 0;
  }

  .labspost__body :global(blockquote) {
    margin: 0;
    padding-left: 16px;
    border-left: 3px solid var(--color-border-solid);
    font-style: italic;
    color: var(--color-text);
  }

  .labspost__body :global(code) {
    font-size: 14px;
    background-color: var(--color-white-2);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .labspost__body :global(pre) {
    margin: 0;
    padding: 16px;
    background-color: var(--color-white-2);
    border-radius: 8px;
    overflow-x: auto;
  }

  .labspost__body :global(pre code) {
    background: none;
    padding: 0;
  }

  .labspost__body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  @media (min-width: 768px) {
    .labspost-article {
      padding-top: 40px;
      padding-bottom: 80px;
      padding-left: max(24px, calc((100% - 1000px) / 2));
      padding-right: max(24px, calc((100% - 1000px) / 2));
    }
  }

  /* ========================
     DIVIDER
     ======================== */
  .labspost__divider {
    border: none;
    height: 1px;
    background-color: var(--color-border-solid);
    margin: 40px 0;
  }

  /* ========================
     AUTHOR + SHARE
     ======================== */
  .labspost__author-share {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .labspost__author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .labspost__author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    object-fit: cover;
    display: block;
  }

  .labspost__author-name {
    font-size: 18px;
    font-weight: 500;
    color: var(--color-dark-blue);
    line-height: normal;
  }

  .labspost__share {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .labspost__share-label {
    font-size: 16px;
    font-weight: 400;
    color: var(--color-dark-blue);
    line-height: normal;
  }

  .labspost__share-icons {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .labspost__share-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    background-color: var(--color-dark-blue);
    color: var(--color-white);
    text-decoration: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s;
  }

  .labspost__share-link:hover {
    opacity: 0.8;
  }

  @media (min-width: 768px) {
    .labspost__author-share {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .labspost__share-icons {
      gap: 14px;
    }

    .labspost__share-link {
      width: 36px;
      height: 36px;
    }
  }

  /* ========================
     PREV/NEXT NAVIGATION
     ======================== */
  .labspost__nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .labspost__nav-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 18px;
    font-weight: 500;
    color: var(--color-dark-blue);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .labspost__nav-link:hover {
    opacity: 0.7;
  }

  /* ========================
     RELATED POSTS
     ======================== */
  .labspost-related {
    background-color: var(--color-white-2);
    padding: 48px 24px;
  }

  .labspost-related__container {
    max-width: var(--container-max);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .labspost-related__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .labspost-related__title {
    font-size: 24px;
    font-weight: 500;
    line-height: normal;
    color: var(--color-dark-blue);
    margin: 0;
    text-align: center;
  }

  .labspost-related__btn-desktop {
    display: none;
  }

  .labspost-related__btn-mobile {
    display: flex;
    justify-content: center;
  }

  .labspost-related__grid {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .labspost-related__grid::-webkit-scrollbar {
    display: none;
  }

  .labspost-related__grid > :global(*) {
    min-width: 280px;
    flex-shrink: 0;
    scroll-snap-align: start;
  }

  @media (min-width: 768px) {
    .labspost-related {
      padding: 80px 120px;
    }

    .labspost-related__container {
      gap: 40px;
    }

    .labspost-related__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }

    .labspost-related__title {
      font-size: 40px;
      text-align: left;
    }

    .labspost-related__btn-desktop {
      display: block;
    }

    .labspost-related__btn-mobile {
      display: none;
    }

    .labspost-related__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      overflow: visible;
    }

    .labspost-related__grid > :global(*) {
      min-width: 0;
    }
  }
</style>

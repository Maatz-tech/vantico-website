---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/HeroSection.astro";
import LogosCarousel from "../components/LogosCarousel.astro";
import HighlightsSection from "../components/HighlightsSection.astro";
import CertificationsSection from "../components/CertificationsSection.astro";
import SolutionsSection from "../components/SolutionsSection.astro";
import CtaSection from "../components/CtaSection.astro";
import TestimonialsSection from "../components/TestimonialsSection.astro";
import BlogSection from "../components/BlogSection.astro";
---

<Base title="Vantico — Especialistas em Segurança Ofensiva" description="A Vantico é referência em pentest e segurança ofensiva, ajudando organizações a identificar e corrigir vulnerabilidades reais antes que sejam exploradas.">
  <Header />

  <main>
    <HeroSection />
    <LogosCarousel />
    <HighlightsSection />
    <CertificationsSection />
    <SolutionsSection />
    <TestimonialsSection />
    <BlogSection />
    <CtaSection />
  </main>

  <Footer />
</Base>

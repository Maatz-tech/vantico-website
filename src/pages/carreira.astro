---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CarreiraHeroSection from '../components/carreira/CarreiraHeroSection.astro';
import ManifestoSection from '../components/carreira/ManifestoSection.astro';
import DNASection from '../components/carreira/DNASection.astro';
import PorDentroSection from '../components/carreira/PorDentroSection.astro';
import RemoteSection from '../components/carreira/RemoteSection.astro';
import CarreiraCTASection from '../components/carreira/CarreiraCTASection.astro';
---

<Base
  title="Carreira — Vantico"
  description="Faça parte da revolução em segurança cibernética. Buscamos profissionais talentosos e apaixonados por cibersegurança para integrar nossa equipe."
>
  <Header />
  <main>
    <CarreiraHeroSection />
    <ManifestoSection />
    <DNASection />
    <PorDentroSection />
    <RemoteSection />
    <CarreiraCTASection />
  </main>
  <Footer />
</Base>
